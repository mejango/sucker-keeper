RELAYR_API=https://api.relayr.ba5ed.com
# Optional for prepaid bundles (sent as x-api-key when set)
RELAYR_API_KEY=

# The keeper's hot wallet. Its address is the deposit address registrants fund
# AND the wallet that pays Relayr prepaid bundles — fully self-managing.
# Generate one: cast wallet new
KEEPER_PRIVATE_KEY=

# Seconds between divergence scans
SCAN_INTERVAL=300

# SQLite file (Railway: mount a volume at /data)
DB_PATH=/data/keeper.db

# Optional per-chain RPC overrides (defaults are public endpoints)
# RPC_1=
# RPC_10=
# RPC_8453=
# RPC_42161=
# RPC_11155111=
# RPC_11155420=
# RPC_84532=
# RPC_421614=
